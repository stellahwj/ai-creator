# ==========================================
# Server 配置
# ==========================================
SERVER_PORT=8000

# ==========================================
# API Keys 配置
# ==========================================
GENAI_API_KEY="your_gemini_api_key"
DASHSCOPE_API_KEY="your_dashscope_api_key"
MINIMAX_API_KEY="your_minimax_api_key"
ARK_API_KEY="your_volcengine_ark_api_key"
OPENAI_API_KEY="your_openai_api_key"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_IMAGE_SIZE="1024x1024"
OPENAI_IMAGE_QUALITY=""
OPENAI_IMAGE_OUTPUT_FORMAT="png"

# ==========================================
# 模型列表配置 (格式: 模型ID:页面展示名称,多个用英文逗号分隔)
# ==========================================
GEMINI_MODELS="gemini-3.1-flash-image:Gemini 3.1 Flash Image"
QWEN_MODELS="qwen-image-2.0-pro:通义千问 Image 2.0 Pro"
MINIMAX_MODELS="minimax-image-01:MiniMax Image-01,minimax-image-01-live:MiniMax Image-01-Live"
DOUBAO_MODELS="doubao-seedream-5-0-260128:豆包 Seedream 5.0"
OPENAI_MODELS="gpt-image-1.5:OpenAI GPT Image 1.5"

# 万相视频模型 (支持参考图/视频生成视频)
WAN_MODELS="wan2.6-r2v-flash:万相 2.6 R2V Flash,wan2.6-r2v:万相 2.6 R2V"

# 图像理解模型（电商场景生图 Step 1）
QWEN_VL_MODEL=qwen3-vl-plus

# 文本推理模型（电商场景生图 Step 2 场景创作）
QWEN_TEXT_MODEL=qwen3-235b-a22b
